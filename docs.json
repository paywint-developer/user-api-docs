{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Paywint Developer API Documentation",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "icon": "rocket",
        "pages": [
          "introduction",
          "environments",
          "authentication",
          "webhook",
          "redirect"
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "Accept Payment",
            "pages": [
              "api-reference/payment/checkout/overview",
              "api-reference/payment/checkout/create-payment-link",
              "api-reference/payment/checkout/create-checkout-token"
            ]
          },
          {
            "group": "Payment",
            "pages": [
              "api-reference/payment/overview",
              "api-reference/payment/get-payment",
              "api-reference/payment/list-sent-payments",
              "api-reference/payment/list-received-payments"
            ]
          },
          {
            "group": "Wallet",
            "pages": [
              "api-reference/wallet/overview",
              "api-reference/wallet/get-wallet"
            ]
          },
          {
            "group": "Paywint Cards",
            "expanded": false,
            "pages": [
              "api-reference/paywint-cards/overview",
              "api-reference/paywint-cards/issue-card",
              "api-reference/paywint-cards/reload-card",
              "api-reference/paywint-cards/list-cards",
              "api-reference/paywint-cards/get-card"
            ]
          },
          {
            "group": "Payee Management",
            "expanded": false,
            "pages": [
              "api-reference/payees/overview",
              "api-reference/payees/create",
              "api-reference/payees/list",
              "api-reference/payees/get",
              "api-reference/payees/update",
              "api-reference/payees/delete"
            ]
          },
          {
            "group": "Payee Addresses",
            "expanded": false,
            "pages": [
              "api-reference/payees/address/overview",
              "api-reference/payees/address/create-address",
              "api-reference/payees/address/list-address",
              "api-reference/payees/address/get-address",
              "api-reference/payees/address/update-address",
              "api-reference/payees/address/set-default-address",
              "api-reference/payees/address/delete-address"
            ]
          }
        ]
      }
    ]
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "interaction": {
    "drilldown": false
  },
  "logo": {
    "light": "/logo/app-logo-dark.png",
    "dark": "/logo/app-logo-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.paywint.com"
      },
      {
        "label": "Support",
        "href": "mailto:support@paywint.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Platform Docs",
      "href": "https://developer.paywint.com"
    }
  },
  "footer": {
    "socials": {
      "youtube": "https://www.youtube.com/@paywint",
      "facebook": "https://www.facebook.com/paywintonline",
      "instagram": "https://www.instagram.com/paywint",
      "x": "https://x.com/paywint",
      "linkedin": "https://www.linkedin.com/company/paywint",
      "threads": "https://www.threads.net/@paywint"
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/introduction"
    }
  ],
  "api": {
    "openapi": {
      "source": "https://api.sandbox.paywint.com/openapi.json",
      "directory": "api-reference"
    }
  },
  "seo": {
    "indexing": "all"
  }
}